# Supabase — Settings → API Keys. Use the NEW key format only.
# The secret key is server-side only and must never be exposed to the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Recommended in production: salts the hashed IPs in the audit log. Without it,
# a random per-process salt is used (non-reversible, but audit hashes won't
# correlate across restarts/instances).
# WISP_IP_SALT=some-long-random-string

# Number of trusted reverse proxies in front of the app. Client IP (used for
# rate limiting + audit hashing) is read that many hops from the RIGHT of
# X-Forwarded-For, so a client-spoofed leftmost value can't defeat throttling.
# Default 1 (a single trusted proxy, e.g. Vercel's edge). Set to your real proxy
# count; set 0 if there is no proxy (X-Forwarded-For is then ignored).
# WISP_TRUSTED_PROXY_DEPTH=1

# Optional: enables POST /api/sweep (expiry cleanup, called by pg_cron).
# Endpoint stays disabled (404) while unset.
# WISP_SWEEP_SECRET=some-long-random-string

# Optional: Clerk sender accounts (SPEC §5b — "My shares" dashboard).
# Both from Clerk Dashboard → API keys. Sender auth stays management-token-only
# while these are unset; recipients NEVER go through Clerk either way.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...   # shipped to the browser (safe to expose)
# CLERK_SECRET_KEY=sk_test_...                    # server-side only
